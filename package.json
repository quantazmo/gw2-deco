{
  "name": "gw2-decoration-editor",
  "version": "0.1.0",
  "description": "Guild Wars 2 Decoration Editor",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc --noEmit && vite build --base=/gw2-deco/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.0",
    "jsdom": "^26.1.0",
    "terser": "^5.47.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.0"
  }
}