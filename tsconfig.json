{
    "compilerOptions": {
        "target": "ES2025",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2025",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true
    },
    "include": [
        "src/**/*",
        "tests/**/*"
    ]
}